+      "time": "18:00",
+      "guests": 2,
+      "reservationNumber": "R-20251215-TEST",
+      "ownerReply": "テストメッセージです"
+    },
+    "storeData": {
+      "name": "テストレストラン",
+      "phoneNumber": "03-1234-5678",
+      "address": "東京都渋谷区○○"
+    }
+  }'
+```
