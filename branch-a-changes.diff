+# Email Configuration (INF-300)
+# AWS SES SMTP設定
+
+# SMTP Host (AWS SES)
+# リージョンに応じて変更: email-smtp.{region}.amazonaws.com
+SMTP_HOST=email-smtp.ap-northeast-1.amazonaws.com
+SMTP_PORT=587
+
+# AWS SES SMTP認証情報
+# AWS Console → SES → SMTP settings → Create SMTP credentials
+# で発行される IAM ユーザーの認証情報
+AWS_SES_SMTP_USER=your-smtp-username
+AWS_SES_SMTP_PASS=your-smtp-password
+
+# 送信元メールアドレス設定
+EMAIL_FROM=noreply@yourdomain.com
+EMAIL_DOMAIN=yourdomain.com
+
+# 開発環境用 (Ethereal.email)
+# https://ethereal.email で無料アカウントを作成
+ETHEREAL_USER=
+ETHEREAL_PASS=
+
+# --- AWS SES 本番設定手順 ---
+# 1. AWS Console → SES → Identities → Create Identity
+# 2. ドメインを追加して DNS 設定（DKIM, SPF）を行う
+# 3. Sandbox 環境では検証済みメールアドレスにのみ送信可能
+# 4. 本番利用時は SES → Account dashboard → Request production access
diff --git a/.env.production.example b/.env.production.example
new file mode 100644
index 0000000..f115ecc
--- /dev/null
+++ b/.env.production.example
@@ -0,0 +1,58 @@
+# 本番環境 環境変数設定
+# INF-303: Production Environment Setup
+
+# === サーバー設定 ===
+HOST=0.0.0.0
+PORT=1337
+NODE_ENV=production
+PUBLIC_URL=https://api.your-domain.com
+PROXY=true
+
+# === Strapi Keys (必須) ===
+# openssl rand -base64 32 で生成
+APP_KEYS=key1,key2,key3,key4
+API_TOKEN_SALT=your-api-token-salt
+ADMIN_JWT_SECRET=your-admin-jwt-secret
+TRANSFER_TOKEN_SALT=your-transfer-token-salt
+JWT_SECRET=your-jwt-secret
+
+# === Database (PostgreSQL推奨) ===
+DATABASE_CLIENT=postgres
+DATABASE_HOST=your-db-host.amazonaws.com
+DATABASE_PORT=5432
+DATABASE_NAME=strapi_production
+DATABASE_USERNAME=strapi_user
+DATABASE_PASSWORD=your-secure-password
+DATABASE_SSL=true
+
+# === AWS SES メール設定 ===
+# SMTPエンドポイント
+SMTP_HOST=email-smtp.ap-northeast-1.amazonaws.com
+SMTP_PORT=587
+
+# AWS SES SMTP認証情報
+# IAM: SES SMTP credentials (not regular IAM credentials)
+AWS_SES_SMTP_USER=your-ses-smtp-username
+AWS_SES_SMTP_PASS=your-ses-smtp-password
+
+# 送信元設定 (SESで検証済みのドメイン)
+EMAIL_FROM=noreply@your-verified-domain.com
+EMAIL_DOMAIN=your-verified-domain.com
+
+# === CORS設定 ===
+# 許可するオリジン（カンマ区切り）
+CORS_ORIGINS=https://your-frontend.com,https://www.your-frontend.com
+
+# === エラー監視 ===
+# Slack/Discord Webhook URL（オプション）
+ERROR_WEBHOOK_URL=https://hooks.slack.com/services/xxx/yyy/zzz
+
+# === LINE通知設定 (Store単位で管理) ===
+# 店舗ごとにStrapi管理画面で設定
+
+# === 本番チェックリスト ===
+# [ ] AWS SES サンドボックス解除完了
+# [ ] DKIM/SPF レコード設定完了
+# [ ] SSL証明書設定済み
+# [ ] データベースバックアップ設定済み
+# [ ] ログ監視設定済み
