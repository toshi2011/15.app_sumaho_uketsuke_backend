{
    "kind": "collectionType",
    "collectionName": "sales_logs",
    "info": {
        "singularName": "sales-log",
        "pluralName": "sales-logs",
        "displayName": "Sales Log",
        "description": "営業活動履歴"
    },
    "options": {
        "draftAndPublish": false
    },
    "pluginOptions": {},
    "attributes": {
        "date": {
            "type": "datetime",
            "required": true
        },
        "action": {
            "type": "enumeration",
            "enum": [
                "DM",
                "Call",
                "Visit"
            ],
            "required": true
        },
        "result": {
            "type": "enumeration",
            "enum": [
                "NoAnswer",
                "Good",
                "Bad",
                "Contract"
            ]
        },
        "note": {
            "type": "text"
        },
        "store": {
            "type": "relation",
            "relation": "manyToOne",
            "target": "api::store.store",
            "inversedBy": "salesLogs"
        }
    }
}