{
    "kind": "collectionType",
    "collectionName": "menu_items",
    "info": {
        "singularName": "menu-item",
        "pluralName": "menu-items",
        "displayName": "Menu Item",
        "description": "店舗のメニュー項目 "
    },
    "options": {
        "draftAndPublish": true
    },
    "pluginOptions": {},
    "attributes": {
        "name": {
            "type": "string",
            "required": true
        },
        "description": {
            "type": "text"
        },
        "price": {
            "type": "integer"
        },
        "image": {
            "type": "media",
            "multiple": false,
            "required": false,
            "allowedTypes": [
                "images"
            ]
        },
        "store": {
            "type": "relation",
            "relation": "manyToOne",
            "target": "api::store.store",
            "inversedBy": "menuItems"
        },
        "isCourse": {
            "type": "boolean",
            "default": false
        },
        "type": {
            "type": "enumeration",
            "enum": [
                "course",
                "display_only"
            ],
            "default": "display_only"
        },
        "minGuests": {
            "type": "integer",
            "default": 1
        },
        "groupOrder": {
            "type": "boolean",
            "default": false
        },
        "duration": {
            "type": "integer",
            "min": 60,
            "max": 180
        },
        "serviceType": {
            "type": "enumeration",
            "enum": [
                "common",
                "day",
                "night"
            ],
            "default": "common"
        }
    }
}