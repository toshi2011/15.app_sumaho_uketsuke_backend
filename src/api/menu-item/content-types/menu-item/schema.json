{
    "kind": "collectionType",
    "collectionName": "menu_items",
    "info": {
        "singularName": "menu-item",
        "pluralName": "menu-items",
        "displayName": "Menu Item",
        "description": "店舗のメニュー項目 "
    },
    "options": {
        "draftAndPublish": true
    },
    "pluginOptions": {},
    "attributes": {
        "name": {
            "type": "string",
            "required": true
        },
        "description": {
            "type": "text"
        },
        "price": {
            "type": "integer"
        },
        "image": {
            "type": "media",
            "multiple": false,
            "required": false,
            "allowedTypes": [
                "images"
            ]
        },
        "store": {
            "type": "relation",
            "relation": "manyToOne",
            "target": "api::store.store",
            "inversedBy": "menuItems"
        }
    }
}