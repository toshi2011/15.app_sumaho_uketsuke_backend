{
    "kind": "collectionType",
    "collectionName": "stores",
    "info": {
        "singularName": "store",
        "pluralName": "stores",
        "displayName": "Store",
        "description": "店舗情報"
    },
    "options": {
        "draftAndPublish": true
    },
    "pluginOptions": {},
    "attributes": {
        "name": {
            "type": "string",
            "required": true
        },
        "status": {
            "type": "enumeration",
            "enum": [
                "LEAD",
                "CONTACTED",
                "TRIAL",
                "REJECTED",
                "DORMANT",
                "ACTIVE"
            ],
            "default": "LEAD"
        },
        "category": {
            "type": "enumeration",
            "enum": [
                "restaurant",
                "izakaya",
                "cafe",
                "salon",
                "classroom",
                "accommodation",
                "other"
            ],
            "default": "restaurant"
        },
        "adminToken": {
            "type": "string",
            "private": true
        },
        "description": {
            "type": "text"
        },
        "phoneNumber": {
            "type": "string"
        },
        "postalCode": {
            "type": "string"
        },
        "address": {
            "type": "string"
        },
        "businessHours": {
            "type": "json"
        },
        "assignmentPriorities": {
            "type": "json"
        },
        "allowOverCapacity": {
            "type": "boolean",
            "default": false
        },
        "snsLink1Label": {
            "type": "string"
        },
        "snsLink1Url": {
            "type": "string"
        },
        "snsLink2Label": {
            "type": "string"
        },
        "snsLink2Url": {
            "type": "string"
        },
        "snsLink3Label": {
            "type": "string"
        },
        "snsLink3Url": {
            "type": "string"
        },
        "snsLink4Label": {
            "type": "string"
        },
        "snsLink4Url": {
            "type": "string"
        },
        "snsLink5Label": {
            "type": "string"
        },
        "snsLink5Url": {
            "type": "string"
        },
        "maxCapacity": {
            "type": "integer",
            "default": 20,
            "min": 1
        },
        "maxGroupsPerSlot": {
            "type": "integer",
            "default": 5,
            "min": 1
        },
        "defaultDuration": {
            "type": "integer",
            "default": 90,
            "min": 30
        },
        "morningDuration": {
            "type": "integer",
            "default": 45,
            "min": 15
        },
        "lunchDuration": {
            "type": "integer",
            "default": 60,
            "min": 30
        },
        "dinnerDuration": {
            "type": "integer",
            "default": 90,
            "min": 30
        },
        "lunchEndTime": {
            "type": "time"
        },
        "cleanUpDuration": {
            "type": "integer",
            "min": 0
        },
        "lunchCleanUp": {
            "type": "integer",
            "default": 0,
            "min": 0
        },
        "dinnerCleanUp": {
            "type": "integer",
            "default": 0,
            "min": 0
        },
        "minBookingLeadTime": {
            "type": "integer",
            "default": 60,
            "min": 0
        },
        "maxDurationLimit": {
            "type": "integer",
            "min": 30
        },
        "allowSameDayBooking": {
            "type": "boolean",
            "default": true
        },
        "sameDayCutoffTime": {
            "type": "time"
        },
        "bookingClosingRule": {
            "type": "enumeration",
            "enum": [
                "strict_closing",
                "last_order_limit"
            ],
            "default": "last_order_limit"
        },
        "dynamicDurationRate": {
            "type": "integer",
            "default": 10,
            "min": 0
        },
        "rejectionStrategy": {
            "type": "enumeration",
            "enum": [
                "call_request",
                "auto_reject"
            ],
            "default": "call_request"
        },
        "bookingAcceptanceMode": {
            "type": "enumeration",
            "enum": [
                "auto",
                "manual_if_notes",
                "manual"
            ],
            "default": "auto"
        },
        "menuItems": {
            "type": "relation",
            "relation": "oneToMany",
            "target": "api::menu-item.menu-item",
            "mappedBy": "store"
        },
        "menuSheetImages": {
            "type": "media",
            "multiple": true,
            "required": false,
            "allowedTypes": [
                "images"
            ]
        },
        "socialLinks": {
            "type": "json"
        },
        "branding": {
            "type": "json"
        },
        "logoImage": {
            "type": "media",
            "multiple": false,
            "required": false,
            "allowedTypes": [
                "images"
            ]
        },
        "coverImage": {
            "type": "media",
            "multiple": false,
            "required": false,
            "allowedTypes": [
                "images"
            ]
        },
        "ownerInfo": {
            "type": "json"
        },
        "digitalPresence": {
            "type": "json"
        },
        "salesLogs": {
            "type": "relation",
            "relation": "oneToMany",
            "target": "api::sales-log.sales-log",
            "mappedBy": "store"
        },
        "reservations": {
            "type": "relation",
            "relation": "oneToMany",
            "target": "api::reservation.reservation",
            "mappedBy": "store"
        },
        "customers": {
            "type": "relation",
            "relation": "oneToMany",
            "target": "api::customer.customer",
            "mappedBy": "store"
        },
        "tables": {
            "type": "relation",
            "relation": "oneToMany",
            "target": "api::table.table",
            "mappedBy": "store"
        },
        "supportedLanguages": {
            "type": "json",
            "default": [
                "ja"
            ]
        },
        "lineChannelAccessToken": {
            "type": "text",
            "private": true
        },
        "lineUserId": {
            "type": "string",
            "private": true
        },
        "store_modules": {
            "type": "relation",
            "relation": "oneToMany",
            "target": "api::store-module.store-module",
            "mappedBy": "store"
        }
    }
}