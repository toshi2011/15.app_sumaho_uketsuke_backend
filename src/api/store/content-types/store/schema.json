{
    "kind": "collectionType",
    "collectionName": "stores",
    "info": {
        "singularName": "store",
        "pluralName": "stores",
        "displayName": "Store",
        "description": "店舗情報"
    },
    "options": {
        "draftAndPublish": true
    },
    "pluginOptions": {},
    "attributes": {
        "name": {
            "type": "string",
            "required": true
        },
        "status": {
            "type": "enumeration",
            "enum": [
                "LEAD",
                "CONTACTED",
                "TRIAL",
                "REJECTED",
                "DORMANT",
                "ACTIVE"
            ],
            "default": "LEAD"
        },
        "adminToken": {
            "type": "string",
            "private": true
        },
        "description": {
            "type": "text"
        },
        "phoneNumber": {
            "type": "string"
        },
        "postalCode": {
            "type": "string"
        },
        "address": {
            "type": "string"
        },
        "businessHours": {
            "type": "json"
        },
        "snsLink1Label": {
            "type": "string"
        },
        "snsLink1Url": {
            "type": "string"
        },
        "snsLink2Label": {
            "type": "string"
        },
        "snsLink2Url": {
            "type": "string"
        },
        "snsLink3Label": {
            "type": "string"
        },
        "snsLink3Url": {
            "type": "string"
        },
        "snsLink4Label": {
            "type": "string"
        },
        "snsLink4Url": {
            "type": "string"
        },
        "snsLink5Label": {
            "type": "string"
        },
        "snsLink5Url": {
            "type": "string"
        },
        "maxCapacity": {
            "type": "integer",
            "default": 20,
            "min": 1
        },
        "maxGroupsPerSlot": {
            "type": "integer",
            "default": 5,
            "min": 1
        },
        "defaultDuration": {
            "type": "integer",
            "default": 90,
            "min": 30
        },
        "menuItems": {
            "type": "relation",
            "relation": "oneToMany",
            "target": "api::menu-item.menu-item",
            "mappedBy": "store"
        },
        "menuSheetImages": {
            "type": "media",
            "multiple": true,
            "required": false,
            "allowedTypes": [
                "images"
            ]
        },
        "socialLinks": {
            "type": "json"
        },
        "branding": {
            "type": "json"
        },
        "logoImage": {
            "type": "media",
            "multiple": false,
            "required": false,
            "allowedTypes": [
                "images"
            ]
        },
        "coverImage": {
            "type": "media",
            "multiple": false,
            "required": false,
            "allowedTypes": [
                "images"
            ]
        },
        "ownerInfo": {
            "type": "json"
        },
        "digitalPresence": {
            "type": "json"
        },
        "salesLogs": {
            "type": "relation",
            "relation": "oneToMany",
            "target": "api::sales-log.sales-log",
            "mappedBy": "store"
        },
        "reservations": {
            "type": "relation",
            "relation": "oneToMany",
            "target": "api::reservation.reservation",
            "mappedBy": "store"
        },
        "customers": {
            "type": "relation",
            "relation": "oneToMany",
            "target": "api::customer.customer",
            "mappedBy": "store"
        },
        "tables": {
            "type": "relation",
            "relation": "oneToMany",
            "target": "api::table.table",
            "mappedBy": "store"
        }
    }
}