{
    "kind": "collectionType",
    "collectionName": "reservations",
    "info": {
        "singularName": "reservation",
        "pluralName": "reservations",
        "displayName": "Reservation",
        "description": "予約情報（詳細モード対応）"
    },
    "options": {
        "draftAndPublish": false
    },
    "pluginOptions": {},
    "attributes": {
        "guestName": {
            "type": "string",
            "required": true
        },
        "email": {
            "type": "email"
        },
        "phone": {
            "type": "string"
        },
        "date": {
            "type": "date",
            "required": true
        },
        "time": {
            "type": "string",
            "required": true
        },
        "duration": {
            "type": "integer",
            "default": 120,
            "min": 15
        },
        "guests": {
            "type": "integer",
            "required": true,
            "min": 1
        },
        "status": {
            "type": "enumeration",
            "enum": [
                "pending",
                "confirmed",
                "rejected",
                "canceled",
                "cancelled",
                "completed",
                "no_show"
            ],
            "default": "pending",
            "required": true
        },
        "assignedTables": {
            "type": "relation",
            "relation": "manyToMany",
            "target": "api::table.table",
            "inversedBy": "reservations"
        },
        "reservationNumber": {
            "type": "string",
            "unique": true
        },
        "isOwnerEntry": {
            "type": "boolean",
            "default": false
        },
        "source": {
            "type": "enumeration",
            "enum": [
                "web",
                "owner",
                "phone",
                "walk_in",
                "google",
                "other"
            ],
            "default": "web"
        },
        "ownerNote": {
            "type": "text"
        },
        "customer": {
            "type": "relation",
            "relation": "manyToOne",
            "target": "api::customer.customer",
            "inversedBy": "reservations"
        },
        "notes": {
            "type": "text"
        },
        "course": {
            "type": "string"
        },
        "language": {
            "type": "string",
            "default": "ja"
        },
        "ownerReply": {
            "type": "text"
        },
        "ownerReplyTranslated": {
            "type": "text"
        },
        "requiresAttention": {
            "type": "boolean",
            "default": false
        },
        "store": {
            "type": "relation",
            "relation": "manyToOne",
            "target": "api::store.store",
            "inversedBy": "reservations"
        },
        "isRead": {
            "type": "boolean",
            "default": false
        },
        "confirmedAt": {
            "type": "datetime"
        },
        "cancelledAt": {
            "type": "datetime"
        },
        "cancelReason": {
            "type": "string"
        },
        "requiresReview": {
            "type": "boolean",
            "default": false
        },
        "reviewReason": {
            "type": "string"
        },
        "endTime": {
            "type": "time"
        },
        "laneIndex": {
            "type": "integer"
        },
        "isOvernight": {
            "type": "boolean",
            "default": false
        },
        "aiAnalysisResult": {
            "type": "json"
        },
        "aiReason": {
            "type": "text"
        },
        "aiAdvice": {
            "type": "text"
        },
        "cancelToken": {
            "type": "string"
        },
        "notesTranslation": {
            "type": "text"
        },
        "emailStatus": {
            "type": "enumeration",
            "enum": [
                "pending",
                "sent",
                "failed"
            ],
            "default": "pending"
        },
        "emailError": {
            "type": "text"
        }
    }
}