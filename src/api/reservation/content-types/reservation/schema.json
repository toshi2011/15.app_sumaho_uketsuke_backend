{
    "kind": "collectionType",
    "collectionName": "reservations",
    "info": {
        "singularName": "reservation",
        "pluralName": "reservations",
        "displayName": "Reservation",
        "description": "予約情報"
    },
    "options": {
        "draftAndPublish": true
    },
    "pluginOptions": {},
    "attributes": {
        "time": {
            "type": "string",
            "required": true
        },
        "name": {
            "type": "string",
            "required": true
        },
        "guests": {
            "type": "integer",
            "required": true,
            "min": 1
        },
        "course": {
            "type": "string"
        },
        "phone": {
            "type": "string"
        },
        "email": {
            "type": "email"
        },
        "date": {
            "type": "date"
        },
        "notes": {
            "type": "text"
        },
        "status": {
            "type": "enumeration",
            "enum": [
                "pending",
                "confirmed",
                "canceled",
                "completed"
            ],
            "default": "pending"
        },
        "isRead": {
            "type": "boolean",
            "default": false
        },
        "store": {
            "type": "relation",
            "relation": "manyToOne",
            "target": "api::store.store",
            "inversedBy": "reservations"
        },
        "customer": {
            "type": "relation",
            "relation": "manyToOne",
            "target": "api::customer.customer",
            "inversedBy": "reservations"
        },
        "assignedTables": {
            "type": "relation",
            "relation": "manyToMany",
            "target": "api::table.table",
            "inversedBy": "reservations"
        }
    }
}