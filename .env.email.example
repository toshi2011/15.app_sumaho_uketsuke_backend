# Email Configuration (INF-300)
# AWS SES SMTP設定

# SMTP Host (AWS SES)
# リージョンに応じて変更: email-smtp.{region}.amazonaws.com
SMTP_HOST=email-smtp.ap-northeast-1.amazonaws.com
SMTP_PORT=587

# AWS SES SMTP認証情報
# AWS Console → SES → SMTP settings → Create SMTP credentials
# で発行される IAM ユーザーの認証情報
AWS_SES_SMTP_USER=your-smtp-username
AWS_SES_SMTP_PASS=your-smtp-password

# 送信元メールアドレス設定
EMAIL_FROM=noreply@yourdomain.com
EMAIL_DOMAIN=yourdomain.com

# 開発環境用 (Ethereal.email)
# https://ethereal.email で無料アカウントを作成
ETHEREAL_USER=
ETHEREAL_PASS=

# --- AWS SES 本番設定手順 ---
# 1. AWS Console → SES → Identities → Create Identity
# 2. ドメインを追加して DNS 設定（DKIM, SPF）を行う
# 3. Sandbox 環境では検証済みメールアドレスにのみ送信可能
# 4. 本番利用時は SES → Account dashboard → Request production access
