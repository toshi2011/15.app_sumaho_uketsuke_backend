# 本番環境 環境変数設定
# INF-303: Production Environment Setup

# === サーバー設定 ===
HOST=0.0.0.0
PORT=1337
NODE_ENV=production
PUBLIC_URL=https://api.your-domain.com
PROXY=true

# === Strapi Keys (必須) ===
# openssl rand -base64 32 で生成
APP_KEYS=key1,key2,key3,key4
API_TOKEN_SALT=your-api-token-salt
ADMIN_JWT_SECRET=your-admin-jwt-secret
TRANSFER_TOKEN_SALT=your-transfer-token-salt
JWT_SECRET=your-jwt-secret

# === Database (PostgreSQL推奨) ===
DATABASE_CLIENT=postgres
DATABASE_HOST=your-db-host.amazonaws.com
DATABASE_PORT=5432
DATABASE_NAME=strapi_production
DATABASE_USERNAME=strapi_user
DATABASE_PASSWORD=your-secure-password
DATABASE_SSL=true

# === AWS SES メール設定 ===
# SMTPエンドポイント
SMTP_HOST=email-smtp.ap-northeast-1.amazonaws.com
SMTP_PORT=587

# AWS SES SMTP認証情報
# IAM: SES SMTP credentials (not regular IAM credentials)
AWS_SES_SMTP_USER=your-ses-smtp-username
AWS_SES_SMTP_PASS=your-ses-smtp-password

# 送信元設定 (SESで検証済みのドメイン)
EMAIL_FROM=noreply@your-verified-domain.com
EMAIL_DOMAIN=your-verified-domain.com

# === CORS設定 ===
# 許可するオリジン（カンマ区切り）
CORS_ORIGINS=https://your-frontend.com,https://www.your-frontend.com

# === エラー監視 ===
# Slack/Discord Webhook URL（オプション）
ERROR_WEBHOOK_URL=https://hooks.slack.com/services/xxx/yyy/zzz

# === LINE通知設定 (Store単位で管理) ===
# 店舗ごとにStrapi管理画面で設定

# === 本番チェックリスト ===
# [ ] AWS SES サンドボックス解除完了
# [ ] DKIM/SPF レコード設定完了
# [ ] SSL証明書設定済み
# [ ] データベースバックアップ設定済み
# [ ] ログ監視設定済み
